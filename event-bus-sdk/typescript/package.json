{
  "name": "@trustlist/event-bus-sdk",
  "version": "0.1.0",
  "description": "TrustList event-bus SDK — TypeScript producer and consumer for the RedPanda event bus (Stage 0 PRD §7b). Wire-interoperable with the Python trustlist_event_bus SDK.",
  "license": "Apache-2.0",
  "author": "The TrustList Foundation",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "generate-types": "ts-node scripts/generate-payload-types.ts",
    "test": "jest",
    "test:unit": "jest test/unit",
    "test:integration": "jest test/integration"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "json-schema-to-typescript": "^15.0.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
